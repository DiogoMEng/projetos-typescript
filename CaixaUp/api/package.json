    "express": "^4.19.2",
    "express-async-errors": "^3.1.1",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.16.3",
    "pg-hstore": "^2.3.4",
    "prettier": "^3.8.3",
    "reflect-metadata": "^0.2.2",
    "sequelize": "^6.37.5",
